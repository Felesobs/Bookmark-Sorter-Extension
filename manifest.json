{
  "manifest_version": 3,
  "name": "Bookmark Auto Sorter",
  "version": "1.0.0",
  "description": "เรียงบุ๊กมาร์กอัตโนมัติตามชื่อหรือวันที่เพิ่ม",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bookmark Auto Sorter"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
